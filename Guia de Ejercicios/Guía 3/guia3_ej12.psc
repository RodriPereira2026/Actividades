Algoritmo sin_titulo
	Definir num1, num2, num3, suma, producto Como Entero
	Escribir "Ingresar el primer número"
	Leer num1
	Escribir "Ingresar el segundo número"
	Leer num2
	Escribir "Ingresar el tercer número"
	Leer num3
	
	suma=num1+num2
	producto=num2*num3
	
	Si suma>producto Entonces
		Escribir "Es mayor la suma"
	FinSi
	
	Escribir "La suma es: " suma
	Escribir "El producto es: " producto
FinAlgoritmo
