Algoritmo sin_titulo
	Definir num1, num2 Como Entero
	Escribir "Ingrese un número"
	Leer num1
	Escribir "Ingrese otro número"
	Leer num2
	
	Si num1 == num2 Entonces
		Escribir "Son Iguales"
	FinSi
	Si num1 > num2 Entonces
		Escribir "El mayor es: " num1
	SiNo
		Escribir "El mayor es: " num2
	FinSi
FinAlgoritmo
