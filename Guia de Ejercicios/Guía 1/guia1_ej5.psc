Algoritmo sin_titulo
	Definir nota1, nota2, nota3, promedio como Real
	Escribir "Ingresar tu primera nota"
	Leer nota1
	Escribir "Ingresar tu segunda nota"
	Leer nota2
	Escribir "Ingresar tu tercer nota"
	Leer nota3
	promedio=(nota1+nota2+nota3) /3
	Escribir "El promedio final es: " promedio
FinAlgoritmo
